flowchart LR
    USER([User])

    subgraph Client["Client (Browser)"]
        direction TB
        UI["AI Chat Panel"]
        EXEC["Tool Executor"]
        UI -->|tool calls| EXEC
        EXEC -->|tool results| UI
        EXEC --- SCENE["3D Scene"]
        EXEC --- STORE["Asset Store"]
    end

    subgraph Server["Server (API)"]
        direction TB
        CHAT["Chat endpoint<br/>(streaming)"]
        SUB["Sub-agent endpoint"]
        TOOLS["Tool definitions<br/>+ prompts"]
        CHAT --- TOOLS
        SUB --- TOOLS
    end

    LLM(["LLM Providers"])

    USER -->|prompt| UI
    UI <-->|messages /<br/>SSE stream| CHAT
    EXEC -->|delegate| SUB
    SUB -->|result| EXEC
    CHAT <--> LLM
    SUB <--> LLM
